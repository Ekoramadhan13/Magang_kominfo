<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="fw-bold"><i class="bi bi-grid text-primary"></i> Daftar Aplikasi</h4>
  <% if (helpers.hasRole(user, 'tim_leader', 'admin')) { %>
  <a href="/applications/create" class="btn btn-primary">
    <i class="bi bi-plus-lg"></i> Tambah Aplikasi
  </a>
  <% } %>
</div>

<div class="card shadow-sm">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-dark">
          <tr>
            <th>No</th><th>Nama Aplikasi</th><th>Versi</th>
            <th>Tim Leader</th><th>Status</th><th>Total Bugs</th>
            <th>Deadline</th><th>Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% apps.forEach((app, i) => { %>
          <tr>
            <td><%= i+1 %></td>
            <td>
              <strong><%= app.nama_aplikasi %></strong>
              <% if (app.deskripsi) { %>
              <br><small class="text-muted"><%= helpers.truncate(app.deskripsi, 50) %></small>
              <% } %>
            </td>
            <td><span class="badge bg-secondary"><%= app.versi || '-' %></span></td>
            <td><%= app.leader_nama || '-' %></td>
            <td>
              <span class="badge bg-<%= helpers.appStatusColor(app.status) %>">
                <%= helpers.capitalize(app.status) %>
              </span>
            </td>
            <td>
              <span class="text-danger fw-bold"><%= app.bugs_open || 0 %> open</span> /
              <span class="text-success"><%= app.bugs_fixed || 0 %> fixed</span>
            </td>
            <td><small><%= helpers.formatDate(app.tanggal_deadline) %></small></td>
            <td>
              <a href="/applications/<%= app.id %>" class="btn btn-sm btn-outline-primary">
                <i class="bi bi-eye"></i>
              </a>
              <% if (helpers.hasRole(user, 'tim_leader', 'admin')) { %>
              <a href="/applications/<%= app.id %>/edit" class="btn btn-sm btn-outline-warning">
                <i class="bi bi-pencil"></i>
              </a>
              <% } %>
              <% if (helpers.hasRole(user, 'admin')) { %>
              <form action="/applications/<%= app.id %>?_method=DELETE" method="POST" 
                    class="d-inline" onsubmit="return confirm('Yakin hapus?')">
                <button class="btn btn-sm btn-outline-danger">
                  <i class="bi bi-trash"></i>
                </button>
              </form>
              <% } %>
            </td>
          </tr>
          <% }) %>
          <% if (apps.length === 0) { %>
          <tr>
            <td colspan="8" class="text-center text-muted py-4">
              Belum ada data aplikasi
            </td>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>