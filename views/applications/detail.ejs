<%- include('../partials/header') %>

  <div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="fw-bold"><i class="bi bi-grid text-primary"></i>
      <%= app.nama_aplikasi %>
    </h4>
    <div class="d-flex gap-2">
      <span class="badge bg-<%= helpers.appStatusColor(app.status) %> fs-6">
        <%= helpers.capitalize(app.status) %>
      </span>
      <% if (helpers.hasRole(user, 'tim_leader' , 'admin' )) { %>
        <a href="/applications/<%= app.id %>/edit" class="btn btn-sm btn-warning"><i class="bi bi-pencil"></i> Edit</a>
        <% } %>
          <a href="/applications" class="btn btn-sm btn-secondary"><i class="bi bi-arrow-left"></i> Kembali</a>
    </div>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-md-4">
      <div class="card shadow-sm h-100">
        <div class="card-header bg-primary text-white fw-bold"><i class="bi bi-info-circle"></i> Info Aplikasi</div>
        <div class="card-body">
          <table class="table table-sm table-borderless">
            <tr>
              <th>Versi</th>
              <td>
                <%= app.versi || '-' %>
              </td>
            </tr>
            <tr>
              <th>Tim Leader</th>
              <td>
                <%= app.leader_nama || '-' %>
              </td>
            </tr>
            <tr>
              <th>Ketua Tester</th>
              <td>
                <%= app.ketua_tester_nama || '-' %>
              </td>
            </tr>
            <tr>
              <th>Tgl Submit</th>
              <td>
                <%= helpers.formatDate(app.tanggal_submit) %>
              </td>
            </tr>
            <tr>
              <th>Deadline</th>
              <td>
                <%= helpers.formatDate(app.tanggal_deadline) %>
              </td>
            </tr>
          </table>
          <% if (app.deskripsi) { %>
            <hr>
            <p class="small text-muted">
              <%= app.deskripsi %>
            </p>
            <% } %>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card shadow-sm h-100">
        <div class="card-header bg-danger text-white fw-bold"><i class="bi bi-bar-chart"></i> Statistik Bug</div>
        <div class="card-body">
          <% const statItems=[ { label: 'Open' , val: bugStats.open, color: 'danger' }, { label: 'In Progress' , val:
            bugStats.in_progress, color: 'warning' }, { label: 'Fixed' , val: bugStats.fixed, color: 'primary' }, {
            label: 'Verified' , val: bugStats.verified, color: 'success' }, { label: 'Closed' , val: bugStats.closed,
            color: 'success' } ] %>
            <% statItems.forEach(s=> { %>
              <div class="d-flex justify-content-between align-items-center mb-2">
                <span>
                  <%= s.label %>
                </span>
                <span class="badge bg-<%= s.color %>">
                  <%= s.val || 0 %>
                </span>
              </div>
              <% }) %>
                <hr>
                <div class="d-flex justify-content-between fw-bold">
                  <span>Total</span><span>
                    <%= bugStats.total || 0 %>
                  </span>
                </div>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card shadow-sm h-100">
        <div class="card-header bg-success text-white fw-bold"><i class="bi bi-people"></i> Tim Tester</div>
        <div class="card-body">
          <% if (testers.length> 0) { %>
            <% testers.forEach(t=> { %>
              <div class="d-flex align-items-center mb-2">
                <i class="bi bi-person-circle text-success me-2"></i>
                <div>
                  <div class="fw-semibold">
                    <%= t.tester_nama %>
                  </div>
                  <small
                    class="badge bg-<%= t.status==='done'?'success':t.status==='on_going'?'warning':'secondary' %>">
                    <%= t.status %>
                  </small>
                </div>
              </div>
              <% }) %>
                <% } else { %>
                  <p class="text-muted small">Belum ada tester ditugaskan</p>
                  <% } %>
        </div>
      </div>
    </div>
  </div>


  <% if (helpers.hasRole(user, 'ketua_tester' , 'admin' )) { %>
    <div class="card shadow-sm mb-4">
      <div class="card-header bg-success text-white fw-bold"><i class="bi bi-person-check"></i> Tugaskan Tester</div>
      <div class="card-body">
        <form action="/applications/<%= app.id %>/assign" method="POST">
          <div class="row g-3">
            <div class="col-md-4">
              <label class="form-label">Ketua Tim Tester</label>
              <select name="ketua_tester_id" class="form-select">
                <option value="">-- Pilih Ketua --</option>
                <% allKetua.forEach(k=> { %>
                  <option value="<%= k.id %>" <%=app.ketua_tester_id==k.id?'selected':'' %>><%= k.nama %>
                  </option>
                  <% }) %>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Pilih Tester (bisa lebih dari satu)</label>
              <select name="tester_ids" class="form-select" multiple>
                <% allTesters.forEach(t=> { %>
                  <option value="<%= t.id %>">
                    <%= t.nama %>
                  </option>
                  <% }) %>
              </select>
              <small class="text-muted">Tahan Ctrl untuk pilih lebih dari satu</small>
            </div>
            <div class="col-md-2 d-flex align-items-end">
              <button type="submit" class="btn btn-success w-100"><i class="bi bi-check"></i> Assign</button>
            </div>
          </div>
        </form>
      </div>
    </div>
    <% } %>


      <div class="card shadow-sm mb-4">
        <div class="card-header bg-info text-white fw-bold d-flex justify-content-between">
          <span><i class="bi bi-list-check"></i> Use Cases (<%= useCases.length %>)</span>
        </div>
        <div class="card-body">
          <% if (helpers.hasRole(user, 'tim_leader' , 'admin' )) { %>
            <button class="btn btn-sm btn-info mb-3" data-bs-toggle="collapse" data-bs-target="#formUseCase">
              <i class="bi bi-plus"></i> Tambah Use Case
            </button>
            <div class="collapse mb-3" id="formUseCase">
              <form action="/applications/use-case/store" method="POST" class="border p-3 rounded bg-light">
                <input type="hidden" name="application_id" value="<%= app.id %>">
                <div class="mb-2">
                  <label class="form-label">Judul Use Case</label>
                  <input type="text" name="judul" class="form-control" required>
                </div>
                <div class="mb-2">
                  <label class="form-label">Deskripsi</label>
                  <textarea name="deskripsi" class="form-control" rows="2"></textarea>
                </div>
                <div class="row">
                  <div class="col-md-6 mb-2">
                    <label class="form-label">Langkah-langkah</label>
                    <textarea name="langkah_langkah" class="form-control" rows="3"></textarea>
                  </div>
                  <div class="col-md-6 mb-2">
                    <label class="form-label">Expected Result</label>
                    <textarea name="expected_result" class="form-control" rows="3"></textarea>
                  </div>
                </div>
                <button type="submit" class="btn btn-info btn-sm"><i class="bi bi-save"></i> Simpan Use Case</button>
              </form>
            </div>
            <% } %>

              <% if (useCases.length> 0) { %>
                <div class="accordion" id="accordionUC">
                  <% useCases.forEach((uc, i)=> { %>
                    <div class="accordion-item">
                      <h2 class="accordion-header">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                          data-bs-target="#uc<%= uc.id %>">
                          <strong>#<%= i+1 %></strong>&nbsp;<%= uc.judul %>
                        </button>
                      </h2>
                      <div id="uc<%= uc.id %>" class="accordion-collapse collapse">
                        <div class="accordion-body">
                          <% if (uc.deskripsi) { %>
                            <p>
                              <%= uc.deskripsi %>
                            </p>
                            <% } %>
                              <div class="row">
                                <% if (uc.langkah_langkah) { %>
                                  <div class="col-md-6">
                                    <strong>Langkah-langkah:</strong>
                                    <pre class="bg-light p-2 rounded small"><%= uc.langkah_langkah %></pre>
                                  </div>
                                  <% } %>
                                    <% if (uc.expected_result) { %>
                                      <div class="col-md-6">
                                        <strong>Expected Result:</strong>
                                        <pre class="bg-light p-2 rounded small"><%= uc.expected_result %></pre>
                                      </div>
                                      <% } %>
                              </div>
                        </div>
                      </div>
                    </div>
                    <% }) %>
                </div>
                <% } else { %>
                  <p class="text-muted">Belum ada use case.</p>
                  <% } %>
        </div>
      </div>


      <div class="card shadow-sm">
        <div class="card-header bg-danger text-white fw-bold d-flex justify-content-between">
          <span><i class="bi bi-bug"></i> Bugs Ditemukan (<%= bugs.length %>)</span>
          <% if (helpers.hasRole(user, 'tester' , 'ketua_tester' )) { %>
            <a href="/bugs/create?appId=<%= app.id %>" class="btn btn-sm btn-light text-danger"><i
                class="bi bi-plus"></i> Laporkan Bug</a>
            <% } %>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr>
                  <th>Judul</th>
                  <th>Severity</th>
                  <th>Priority</th>
                  <th>Status</th>
                  <th>Tester</th>
                  <th>Tgl</th>
                  <th>Aksi</th>
                </tr>
              </thead>
              <tbody>
                <% bugs.forEach(bug=> { %>
                  <tr>
                    <td>
                      <%= helpers.truncate(bug.judul, 40) %>
                    </td>
                    <td><span class="badge bg-<%= helpers.severityColor(bug.severity) %>">
                        <%= bug.severity %>
                      </span></td>
                    <td><span class="badge bg-<%= helpers.priorityColor(bug.priority) %>">
                        <%= bug.priority %>
                      </span></td>
                    <td><span class="badge bg-<%= helpers.statusColor(bug.status) %>">
                        <%= helpers.capitalize(bug.status) %>
                      </span></td>
                    <td><small>
                        <%= bug.tester_nama %>
                      </small></td>
                    <td><small>
                        <%= helpers.formatDate(bug.created_at, 'DD/MM/YY' ) %>
                      </small></td>
                    <td><a href="/bugs/<%= bug.id %>" class="btn btn-sm btn-outline-primary"><i
                          class="bi bi-eye"></i></a></td>
                  </tr>
                  <% }) %>
                    <% if (bugs.length===0) { %>
                      <tr>
                        <td colspan="7" class="text-center text-muted py-3">Belum ada bug dilaporkan</td>
                      </tr>
                      <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <%- include('../partials/footer') %>