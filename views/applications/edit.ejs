<%- include('../partials/header') %>

<div class="row justify-content-center">
  <div class="col-md-8">
    <div class="card shadow-sm">
      <div class="card-header bg-warning text-dark">
        <h5 class="mb-0"><i class="bi bi-pencil"></i> Edit Aplikasi</h5>
      </div>
      <div class="card-body">
        <form action="/applications/<%= app.id %>?_method=PUT" method="POST">
          <div class="mb-3">
            <label class="form-label fw-semibold">Nama Aplikasi</label>
            <input type="text" name="nama_aplikasi" class="form-control" 
                   value="<%= app.nama_aplikasi %>" required>
          </div>
          <div class="row">
            <div class="col-md-4 mb-3">
              <label class="form-label fw-semibold">Versi</label>
              <input type="text" name="versi" class="form-control" 
                     value="<%= app.versi || '' %>">
            </div>
            <div class="col-md-4 mb-3">
              <label class="form-label fw-semibold">Tanggal Deadline</label>
              <input type="date" name="tanggal_deadline" class="form-control"
                value="<%= app.tanggal_deadline ? app.tanggal_deadline.toISOString().split('T')[0] : '' %>">
            </div>
            <div class="col-md-4 mb-3">
              <label class="form-label fw-semibold">Status</label>
              <select name="status" class="form-select">
                <option value="pending" <%= app.status==='pending'?'selected':'' %>>Pending</option>
                <option value="testing" <%= app.status==='testing'?'selected':'' %>>Testing</option>
                <option value="in_progress" <%= app.status==='in_progress'?'selected':'' %>>In Progress</option>
                <option value="selesai" <%= app.status==='selesai'?'selected':'' %>>Selesai</option>
              </select>
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Deskripsi</label>
            <textarea name="deskripsi" class="form-control" rows="4">
              <%= app.deskripsi || '' %>
            </textarea>
          </div>
          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-warning">
              <i class="bi bi-save"></i> Update
            </button>
            <a href="/applications/<%= app.id %>" class="btn btn-secondary">
              <i class="bi bi-arrow-left"></i> Batal
            </a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>