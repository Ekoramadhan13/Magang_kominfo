<%- include('../partials/header') %>

  <div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="fw-bold"><i class="bi bi-bug text-danger"></i> Detail Bug #<%= bug.id %>
    </h4>
    <a href="/bugs" class="btn btn-sm btn-secondary"><i class="bi bi-arrow-left"></i> Kembali</a>
  </div>

  <div class="row g-3">
    <div class="col-md-8">
      <% if (bug.status==='in_progress' && history.length> 0) {
        const lastHistory = history[history.length - 1];
        if (lastHistory.status_baru === 'in_progress' && lastHistory.status_lama === 'fixed') { %>
        <div class="alert alert-danger border-start border-4 border-danger shadow-sm">
          <h6 class="fw-bold"><i class="bi bi-x-circle-fill"></i> Alasan Bug Ditolak (Oleh Tester)</h6>
          <p class="mb-0">
            <%= lastHistory.keterangan || 'Tidak ada catatan tambahan.' %>
          </p>
        </div>
        <% } } %>

          <div class="card shadow-sm mb-3">
            <div class="card-header bg-white fw-bold d-flex justify-content-between">
              <span>
                <%= bug.judul %>
              </span>
              <span class="badge bg-<%= helpers.statusColor(bug.status) %> fs-6">
                <%= helpers.capitalize(bug.status) %>
              </span>
            </div>
            <div class="card-body">
              <div class="row mb-3">
                <div class="col-md-3"><strong>Aplikasi:</strong></div>
                <div class="col-md-9">
                  <%= bug.nama_aplikasi %>
                </div>
                <% if (bug.use_case_judul) { %>
                  <div class="col-md-3"><strong>Use Case:</strong></div>
                  <div class="col-md-9">
                    <%= bug.use_case_judul %>
                  </div>
                  <% } %>
                    <div class="col-md-3"><strong>Severity:</strong></div>
                    <div class="col-md-9"><span class="badge bg-<%= helpers.severityColor(bug.severity) %>">
                        <%= bug.severity %>
                      </span></div>
                    <div class="col-md-3"><strong>Priority:</strong></div>
                    <div class="col-md-9"><span class="badge bg-<%= helpers.priorityColor(bug.priority) %>">
                        <%= bug.priority %>
                      </span></div>
                    <div class="col-md-3"><strong>Tester:</strong></div>
                    <div class="col-md-9">
                      <%= bug.tester_nama %>
                    </div>
                    <div class="col-md-3"><strong>Ditugaskan ke:</strong></div>
                    <div class="col-md-9">
                      <%= bug.programmer_nama || '-' %>
                        <% if (bug.assigned_role) { %><small class="badge bg-secondary">
                            <%= bug.assigned_role %>
                          </small>
                          <% } %>
                    </div>
                    <div class="col-md-3"><strong>Dilaporkan:</strong></div>
                    <div class="col-md-9"><small>
                        <%= helpers.formatDateTime(bug.created_at) %>
                      </small></div>
                    <% if (bug.tanggal_fixed) { %>
                      <div class="col-md-3"><strong>Tgl Fixed:</strong></div>
                      <div class="col-md-9"><small>
                          <%= helpers.formatDate(bug.tanggal_fixed) %>
                        </small></div>
                      <% } %>
              </div>

              <hr>
              <h6 class="fw-bold">Deskripsi</h6>
              <p>
                <%= bug.deskripsi %>
              </p>

              <% if (bug.langkah_reproduksi) { %>
                <h6 class="fw-bold">Langkah Reproduksi</h6>
                <pre class="bg-light p-2 rounded small"><%= bug.langkah_reproduksi %></pre>
                <% } %>

                  <div class="row">
                    <% if (bug.expected_result) { %>
                      <div class="col-md-6">
                        <h6 class="fw-bold text-success">Expected Result</h6>
                        <p class="small bg-success bg-opacity-10 p-2 rounded">
                          <%= bug.expected_result %>
                        </p>
                      </div>
                      <% } %>
                        <% if (bug.actual_result) { %>
                          <div class="col-md-6">
                            <h6 class="fw-bold text-danger">Actual Result</h6>
                            <p class="small bg-danger bg-opacity-10 p-2 rounded">
                              <%= bug.actual_result %>
                            </p>
                          </div>
                          <% } %>
                  </div>

                  <% if (bug.screenshot) { %>
                    <h6 class="fw-bold">Screenshot</h6>
                    <a href="/uploads/<%= bug.screenshot %>" target="_blank">
                      <img src="/uploads/<%= bug.screenshot %>" class="img-fluid rounded" style="max-height:300px">
                    </a>
                    <% } %>

                      <% if (bug.komentar_programmer) { %>
                        <hr>
                        <h6 class="fw-bold">Komentar Programmer/DSI</h6>
                        <div class="alert alert-info">
                          <%= bug.komentar_programmer %>
                        </div>
                        <% } %>
            </div>
          </div>
    </div>

    <div class="col-md-4">

      <% if (helpers.hasRole(user, 'admin' , 'ketua_tester' , 'tim_leader' ) && bug.status==='open' ) { %>
        <div class="card shadow-sm mb-3">
          <div class="card-header bg-warning text-dark fw-bold"><i class="bi bi-person-check"></i> Tugaskan Bug</div>
          <div class="card-body">
            <form action="/bugs/<%= bug.id %>/assign" method="POST">
              <div class="mb-2">
                <label class="form-label small">Tugaskan ke</label>
                <select name="assigned_to" class="form-select form-select-sm" required>
                  <option value="">-- Pilih --</option>
                  <% programmers.forEach(p=> { %>
                    <option value="<%= p.id %>" data-role="<%= p.role %>">
                      <%= p.nama %> (<%= p.role %>)
                    </option>
                    <% }) %>
                </select>
              </div>
              <div class="mb-2">
                <label class="form-label small">Role</label>
                <select name="assigned_role" id="roleSelect" class="form-select form-select-sm" required>
                  <option value="">-- Pilih Role --</option>
                </select>
              </div>
              <button type="submit" class="btn btn-warning btn-sm w-100">Tugaskan</button>
            </form>
          </div>
        </div>
        <% } %>

          <% if (helpers.hasRole(user, 'programmer' , 'dsi' ) && (bug.status==='in_progress' || bug.status==='open' ||
            bug.status==='rejected' )) { %>
            <div class="card shadow-sm mb-3">
              <div class="card-header bg-primary text-white fw-bold"><i class="bi bi-arrow-repeat"></i> Update Status
              </div>
              <div class="card-body">
                <form action="/bugs/<%= bug.id %>/status?_method=PUT" method="POST">
                  <div class="mb-2">
                    <label class="form-label small">Status Baru</label>
                    <select name="status" class="form-select form-select-sm" required>
                      <option value="in_progress">In Progress</option>
                      <option value="fixed">Fixed - Sudah Diperbaiki</option>
                    </select>
                  </div>
                  <div class="mb-2">
                    <label class="form-label small">Komentar Perbaikan</label>
                    <textarea name="komentar_programmer" class="form-control form-control-sm" rows="3"
                      placeholder="Jelaskan apa yang diperbaiki..."></textarea>
                  </div>
                  <button type="submit" class="btn btn-primary btn-sm w-100"><i class="bi bi-check"></i> Update</button>
                </form>
              </div>
            </div>
            <% } %>

              <% if (helpers.hasRole(user, 'tester' , 'ketua_tester' ) && bug.status==='fixed' ) { %>
                <div class="card shadow-sm mb-3">
                  <div class="card-header bg-success text-white fw-bold"><i class="bi bi-patch-check"></i> Verifikasi
                    Bug</div>
                  <div class="card-body">
                    <p class="small">Bug sudah diperbaiki. Silakan verifikasi apakah perbaikan sudah benar.</p>
                    <form action="/bugs/<%= bug.id %>/verify?_method=PUT" method="POST" class="mb-2">
                      <input type="hidden" name="action" value="verified">
                      <textarea name="catatan" class="form-control form-control-sm mb-2"
                        placeholder="Catatan (opsional)" rows="2"></textarea>
                      <button type="submit" class="btn btn-success w-100"><i class="bi bi-check-circle"></i> Verified -
                        Sudah Benar</button>
                    </form>
                    <form action="/bugs/<%= bug.id %>/verify?_method=PUT" method="POST">
                      <input type="hidden" name="action" value="rejected">
                      <textarea name="catatan" class="form-control form-control-sm mb-2"
                        placeholder="Alasan penolakan..." rows="2"></textarea>
                      <button type="submit" class="btn btn-outline-danger w-100"><i class="bi bi-x-circle"></i> Reject -
                        Belum Benar</button>
                    </form>
                  </div>
                </div>
                <% } %>

                  <div class="card shadow-sm">
                    <div class="card-header bg-secondary text-white fw-bold"><i class="bi bi-clock-history"></i> Riwayat
                    </div>
                    <div class="card-body p-0">
                      <% if (history.length> 0) { %>
                        <ul class="list-group list-group-flush">
                          <% history.forEach(h=> { %>
                            <li class="list-group-item py-2">
                              <div class="d-flex justify-content-between">
                                <small class="fw-semibold">
                                  <%= h.user_nama %>
                                </small>
                                <small class="text-muted">
                                  <%= helpers.formatDateTime(h.created_at) %>
                                </small>
                              </div>
                              <div class="small">
                                <span class="badge bg-secondary">
                                  <%= h.status_lama %>
                                </span>
                                <i class="bi bi-arrow-right"></i>
                                <span class="badge bg-<%= helpers.statusColor(h.status_baru) %>">
                                  <%= h.status_baru %>
                                </span>
                              </div>
                              <% if (h.keterangan) { %>
                                <div class="text-muted mt-1"
                                  style="font-size: 0.85rem; background: #f8f9fa; padding: 5px; border-radius: 4px;">
                                  <i class="bi bi-chat-left-text me-1"></i>
                                  <%= h.keterangan %>
                                </div>
                                <% } %>
                            </li>
                            <% }) %>
                        </ul>
                        <% } else { %>
                          <p class="text-muted small p-3 mb-0">Belum ada riwayat.</p>
                          <% } %>
                    </div>
                  </div>
    </div>
  </div>

  <script>
    document.querySelector('select[name="assigned_to"]').addEventListener('change', function () {
      const selectedOption = this.options[this.selectedIndex];
      const role = selectedOption.getAttribute('data-role');
      const roleSelect = document.getElementById('roleSelect');

      roleSelect.innerHTML = '';

      if (!role) {
        roleSelect.innerHTML = '<option value="">-- Pilih Role --</option>';
        return;
      }

      if (role === 'programmer') {
        roleSelect.innerHTML = `
          <option value="Programmer Backend">Programmer Backend</option>
          <option value="Programmer Frontend">Programmer Frontend</option>
        `;
      } else if (role === 'dsi') {
        roleSelect.innerHTML = `
          <option value="DSI (Desainer UI/UX)">DSI (Desainer UI/UX)</option>
        `;
      }
    });
  </script>

  <%- include('../partials/footer') %>