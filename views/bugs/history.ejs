<%- include('../partials/header') %>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0">
            <i class="bi bi-clock-history text-primary"></i>
            <%= title %>
        </h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                <li class="breadcrumb-item active" aria-current="page">Riwayat</li>
            </ol>
        </nav>
    </div>

    <div class="card border-0 shadow-sm overflow-hidden" style="border-radius: 12px;">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4 py-3" style="width: 200px;">Waktu</th>
                            <th class="py-3">Aktivitas</th>
                            <th class="py-3">Aplikasi</th>
                            <th class="py-3">Oleh</th>
                            <th class="pe-4 py-3 text-end">Aksi</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (history.length> 0) { %>
                            <% history.forEach(h=> { %>
                                <tr>
                                    <td class="ps-4">
                                        <div class="small fw-semibold text-dark">
                                            <%= helpers.formatDate(h.created_at) %>
                                        </div>
                                        <div class="text-muted small" style="font-size: 0.75rem;">
                                            <%= helpers.formatDateTime(h.created_at).split(' ')[1] %></div>
                                </td>
                                <td>
                                    <div class="fw-bold mb-1"><%= helpers.truncate(h.bug_judul, 40) %></div>
                                    <div class="small">
                                        <span class="badge bg-secondary-subtle text-secondary border border-secondary" style="font-size: 0.7rem;">
                                            <%= h.status_lama %>
                                        </span>
                                        <i class="bi bi-arrow-right mx-1 text-muted"></i>
                                        <span class="badge bg-<%= helpers.statusColor(h.status_baru) %>" style="font-size: 0.7rem;">
                                            <%= helpers.capitalize(h.status_baru) %>
                                        </span>
                                    </div>
                                    <% if (h.keterangan) { %>
                                        <div class="text-muted mt-1 small italic" style="font-size: 0.8rem;">
                                            "<%= h.keterangan %>"
                                        </div>
                                    <% } %>
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark border"><%= h.nama_aplikasi %></span>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 24px; height: 24px; font-size: 0.7rem;">
                                            <%= h.user_nama.charAt(0).toUpperCase() %>
                                        </div>
                                        <span class="small"><%= h.user_nama %></span>
                                    </div>
                                </td>
                                <td class="pe-4 text-end">
                                    <a href="/bugs/<%= h.bug_id %>" class="btn btn-sm btn-outline-primary rounded-pill px-3" style="font-size: 0.75rem;">
                                        Detail
                                    </a>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <div class="text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-3 opacity-25"></i>
                                    <p class="mb-0">Belum ada riwayat aktivitas yang tercatat.</p>
                                </div>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>