<%- include('../partials/header') %>

  <div class="card border-0 shadow-sm mb-4 overflow-hidden"
    style="border-radius: 12px; background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);">
    <div class="card-body p-4 d-flex justify-content-between align-items-center">
      <div>
        <h4 class="fw-bold mb-1"><i class="bi bi-person-badge text-primary"></i> Dashboard <%=
            helpers.capitalize(user.role.replace('_', ' ' )) %>
        </h4>
        <p class="text-muted mb-0">Selamat datang kembali, <strong>
            <%= user.nama %>
          </strong>. Ini adalah ringkasan aktivitas <%= user.role==='admin' ? 'sistem' : 'Anda' %>.</p>
      </div>
      <div class="text-end d-none d-md-block">
        <span class="badge bg-white text-dark border p-2"><i class="bi bi-calendar3 me-1"></i>
          <%= new Date().toLocaleDateString('id-ID', { weekday: 'long' , year: 'numeric' , month: 'long' ,
            day: 'numeric' }) %>
        </span>
      </div>
    </div>
  </div>


  <div class="row g-3 mb-4">
    
    <div class="<%= ['admin', 'tim_leader', 'ketua_tester'].includes(user.role) ? 'col-md-7' : 'col-12' %>">
      <div class="row g-3">
        <div class="col-6 col-md-3">
          <div class="card border-0 bg-danger text-white h-100 shadow-sm card-hover">
            <div class="card-body text-center py-3">
              <i class="bi bi-exclamation-circle fs-3"></i>
              <h4 class="fw-bold mt-2 mb-0">
                <%= bugStats.open || 0 %>
              </h4>
              <div class="small opacity-75">Bugs Open</div>
            </div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="card border-0 bg-warning text-dark h-100 shadow-sm card-hover">
            <div class="card-body text-center py-3">
              <i class="bi bi-arrow-repeat fs-3"></i>
              <h4 class="fw-bold mt-2 mb-0">
                <%= bugStats.in_progress || 0 %>
              </h4>
              <div class="small opacity-75">In Progress</div>
            </div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="card border-0 bg-primary text-white h-100 shadow-sm card-hover">
            <div class="card-body text-center py-3">
              <i class="bi bi-check-circle fs-3"></i>
              <h4 class="fw-bold mt-2 mb-0">
                <%= bugStats.fixed || 0 %>
              </h4>
              <div class="small opacity-75">Fixed</div>
            </div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="card border-0 bg-success text-white h-100 shadow-sm card-hover">
            <div class="card-body text-center py-3">
              <i class="bi bi-patch-check fs-3"></i>
              <h4 class="fw-bold mt-2 mb-0">
                <%= bugStats.verified || 0 %>
              </h4>
              <div class="small opacity-75">Verified</div>
            </div>
          </div>
        </div>
      </div>
    </div>


    <% if (['admin', 'tim_leader' , 'ketua_tester' ].includes(user.role)) { %>
      <div class="col-md-5">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body p-3">
            <h6 class="fw-bold mb-3"><i class="bi bi-grid-fill text-muted me-1"></i> Status Aplikasi</h6>
            <div class="row g-2">
              <div class="col-4">
                <div class="p-2 border rounded text-center">
                  <div class="h5 fw-bold mb-0 text-secondary">
                    <%= appStats.total || 0 %>
                  </div>
                  <div class="small text-muted">Total</div>
                </div>
              </div>
              <div class="col-4">
                <div class="p-2 border rounded text-center">
                  <div class="h5 fw-bold mb-0 text-warning">
                    <%= appStats.testing || 0 %>
                  </div>
                  <div class="small text-muted">Testing</div>
                </div>
              </div>
              <div class="col-4">
                <div class="p-2 border rounded text-center">
                  <div class="h5 fw-bold mb-0 text-success">
                    <%= appStats.selesai || 0 %>
                  </div>
                  <div class="small text-muted">Selesai</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <% } %>
  </div>

  <div class="row g-4">
  
    <div class="<%= ['admin', 'tim_leader', 'ketua_tester'].includes(user.role) ? 'col-md-7' : 'col-12' %>">
      <div class="card shadow-sm border-0" style="border-radius: 12px;">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
          <h6 class="fw-bold mb-0"><i class="bi bi-bug-fill text-danger me-1"></i> Bug Terbaru</h6>
          <a href="/bugs" class="btn btn-sm btn-link text-decoration-none p-0">Lihat Semua <i
              class="bi bi-arrow-right"></i></a>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th class="ps-3 border-0">Judul</th>
                  <th class="border-0">Severity</th>
                  <th class="border-0">Status</th>
                </tr>
              </thead>
              <tbody>
                <% recentBugs.forEach(bug=> { %>
                  <tr>
                    <td class="ps-3">
                      <div class="fw-bold small"><a href="/bugs/<%= bug.id %>" class="text-dark text-decoration-none">
                          <%= helpers.truncate(bug.judul, 35) %>
                        </a></div>
                      <small class="text-muted">
                        <%= bug.nama_aplikasi %>
                      </small>
                    </td>
                    <td>
                      <span
                        class="badge bg-<%= helpers.severityColor(bug.severity) %>-subtle text-<%= helpers.severityColor(bug.severity) %> border border-<%= helpers.severityColor(bug.severity) %>"
                        style="font-size: 0.7rem;">
                        <%= bug.severity.toUpperCase() %>
                      </span>
                    </td>
                    <td>
                      <span class="badge bg-<%= helpers.statusColor(bug.status) %>" style="font-size: 0.7rem;">
                        <%= helpers.capitalize(bug.status) %>
                      </span>
                    </td>
                  </tr>
                  <% }) %>
                    <% if (recentBugs.length===0) { %>
                      <tr>
                        <td colspan="3" class="text-center text-muted py-4">
                          <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                          Belum ada bug yang dilaporkan
                        </td>
                      </tr>
                      <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>


    <% if (['admin', 'tim_leader' , 'ketua_tester' ].includes(user.role)) { %>
      <div class="col-md-5">
        <div class="card shadow-sm border-0" style="border-radius: 12px;">
          <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h6 class="fw-bold mb-0"><i class="bi bi-grid-fill text-primary me-1"></i>
              <%= ['admin', 'tim_leader' , 'ketua_tester' ].includes(user.role) ? 'Aplikasi Terbaru'
                : 'Aplikasi Terkait' %>
            </h6>
            <a href="/applications" class="btn btn-sm btn-link text-decoration-none p-0">Lihat Semua <i
                class="bi bi-arrow-right"></i></a>
          </div>
          <div class="list-group list-group-flush">
            <% recentApps.forEach(app=> { %>
              <div class="list-group-item list-group-item-action py-3 border-0 border-bottom">
                <div class="d-flex w-100 justify-content-between align-items-center mb-1">
                  <h6 class="mb-0 fw-bold"><a href="/applications/<%= app.id %>"
                      class="text-primary text-decoration-none">
                      <%= helpers.truncate(app.nama_aplikasi, 25) %>
                    </a></h6>
                  <span
                    class="badge rounded-pill bg-<%= helpers.appStatusColor(app.status) %>-subtle text-<%= helpers.appStatusColor(app.status) %> border border-<%= helpers.appStatusColor(app.status) %>"
                    style="font-size: 0.65rem;">
                    <%= helpers.capitalize(app.status) %>
                  </span>
                </div>
                <div class="d-flex justify-content-between align-items-center">
                  <small class="text-muted"><i class="bi bi-person me-1"></i>
                    <%= app.leader_nama || 'No Leader' %>
                  </small>
                  <small class="text-muted" style="font-size: 0.75rem;">
                    <%= helpers.formatDate(app.created_at) %>
                  </small>
                </div>
              </div>
              <% }) %>
                <% if (recentApps.length===0) { %>
                  <div class="list-group-item text-center text-muted py-4 border-0">
                    <i class="bi bi-folder-x fs-2 d-block mb-2"></i>
                    Belum ada aplikasi ditugaskan
                  </div>
                  <% } %>
          </div>
        </div>
      </div>
      <% } %>
  </div>

  <%- include('../partials/footer') %>